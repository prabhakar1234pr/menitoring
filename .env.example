# Supabase — project fvanlebqknfdodermmbn
# Public (client-side) values: safe to ship in the browser / extension.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only secret (Vercel env, NEVER expose to the client).
# Get it from: Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Groq LLM (server-only). Get it from: https://console.groq.com/keys
GROQ_API_KEY=

# Shared secret guarding POST /api/cron/summarize (pg_cron → pg_net calls it with this).
CRON_SECRET=
